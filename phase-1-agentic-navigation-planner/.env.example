# Phase 1 Agentic Navigation Planner — copy to .env and fill in

# LLM: Nova Lite (Bedrock). Use model id for your region.
MODEL=us.amazon.nova-lite-v1:0

# DeepRacer web console (same IP as in browser)
DEEPRACER_IP=192.168.0.3
DEEPRACER_PASSWORD=your_password_here

# Optional: motion tuning (defaults shown)
# DEEPRACER_FWD_THROTTLE=0.3
# DEEPRACER_TURN_THROTTLE=0.2
# DEEPRACER_MAX_SPEED=1.0
# DEEPRACER_STEER_ANGLE=0.5

# AWS (for Bedrock)
AWS_REGION=us-east-1
